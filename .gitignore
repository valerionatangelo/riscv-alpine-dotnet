# =============================================================================
# .gitignore for the .NET RISC-V Alpine build workspace
# =============================================================================

# ── Large generated directories ───────────────────────────────────────────────

# The dotnet VMR clone (~20 GB) — never commit
dotnet-src/

# Docker build context staging area (holds a copy of the large SDK tarball)
docker/context/

# ── Build outputs ─────────────────────────────────────────────────────────────

# Any SDK tarballs downloaded or copied locally
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── PowerShell ────────────────────────────────────────────────────────────────

# Script analysis settings (generated by VS Code PS extension)
.PSScriptAnalyzerSettings.psd1

# ── Docker ────────────────────────────────────────────────────────────────────

# Exported image tarballs
*.dockersave
*.dockerimage

# ── Editors ───────────────────────────────────────────────────────────────────

# Visual Studio Code
.vscode/

# JetBrains (Rider, etc.)
.idea/
*.iml

# Vim / Emacs swap files
*.swp
*.swo
*~
\#*\#

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
